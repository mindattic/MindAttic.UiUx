{
  "$comment": "Canonical map of which MindAttic.UiUx components flow to each downstream subscriber, with per-subscriber configuration. Sync scripts read this file to drive their splicing -- edit THIS file (not the sync scripts) when adding or removing subscriptions. Marker names are base names (without .CSS suffix); each subscriber kind appends the suffix it needs. NOTE: catalog landing pages (IdiotProof, GridGame2026, MindAttic.Legion, MindAttic.Mobile, MediaButler, MindAttic.Vault, TaxRateCollector, ThinkTank, Tutor, MindAttic.Psst index) and the long-form HTML builds (Claudia, ChiMesh) are owned by MindAttic.Deploy now; they pull components from jsDelivr at runtime instead of being spliced here.",

  "components": {
    "OutfitFont":  { "type": "font-css",    "marker": "OUTFITFONT",  "cssFile": "Components/OutfitFont/outfit-font.css",   "jsonFile": "Components/OutfitFont/outfit-font.json", "htmlFile": "Components/OutfitFont/outfit-font.html" },
    "AtticFont":   { "type": "font-css",    "marker": "ATTICFONT",   "cssFile": "Components/AtticFont/attic-font.css",     "jsonFile": "Components/AtticFont/attic-font.json",   "htmlFile": "Components/AtticFont/attic-font.html"  },
    "BackHomeM":   { "type": "static-css",  "marker": "BACKHOMEM",   "cssFile": "Components/BackHomeM/back-home-m.css" },
    "Cyberspace":  { "type": "html-bundle", "marker": "CYBERSPACE",  "htmlFile": "Components/Cyberspace/frontpage.html",   "cssFile": "Components/Cyberspace/frontpage.css",     "jsFiles": ["Components/Cyberspace/loader.js", "Components/Cyberspace/tv-static.js", "Components/Cyberspace/home-bg.js", "Components/Cyberspace/console-bg.js"], "assetsDir": "Components/Cyberspace/assets" },
    "PinFooter":   { "type": "html-bundle", "marker": "PINFOOTER",   "htmlFile": "Components/PinFooter/pin-footer.html",   "cssFile": "Components/PinFooter/pin-footer.css",     "jsFiles": ["Components/PinFooter/pin-footer.js"] },
    "WebSnapshot": { "type": "html-bundle", "marker": "WEBSNAPSHOT",                                                       "cssFile": "Components/WebSnapshot/web-snapshot.css", "jsFiles": ["Components/WebSnapshot/web-snapshot-viewer.js"] }
  },

  "subscribers": {
    "mindattic.com": {
      "kind":       "html-inline",
      "target":     "D:/Projects/MindAttic/mindattic.com/index.htm",
      "syncScript": "sync-mindattic-com.ps1",
      "subscriptions": [
        { "component": "OutfitFont" },
        { "component": "AtticFont",   "applyToSelector": ".site-name" },
        { "component": "Cyberspace"  },
        { "component": "PinFooter"   },
        { "component": "WebSnapshot" }
      ]
    },

    "StreetSamurai": {
      "kind":       "blazor-wwwroot",
      "target":     "D:/Projects/MindAttic/StreetSamurai/v3/StreetSamurai.Blazor",
      "syncScript": "sync-streetsamurai.ps1",
      "subscriptions": [
        { "component": "OutfitFont" },
        { "component": "AtticFont",  "applyToSelector": null },
        { "component": "Cyberspace" },
        { "component": "PinFooter", "jsOnly": true }
      ]
    },

    "MindAttic.Psst.Legal": {
      "kind":       "html-inline-multi",
      "target":     "D:/Projects/MindAttic/MindAttic.Psst",
      "targets":    ["privacy.htm", "terms.htm"],
      "syncScript": "sync-mindattic-psst.ps1",
      "subscriptions": [
        { "component": "OutfitFont" }
      ]
    }
  }
}
